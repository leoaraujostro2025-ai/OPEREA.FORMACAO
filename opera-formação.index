  { nome: "Retroescavadeira", descricao: "Treinamento para quem quer entrar rápido no mercado com uma máquina muito requisitada." },
  { nome: "Pá Carregadeira", descricao: "Capacitação objetiva para atuação em obras, pátios, mineração e movimentação de materiais." },
  { nome: "Trator de Esteiras", descricao: "Curso voltado para operação com precisão, controle e domínio em terrenos pesados." },
];

