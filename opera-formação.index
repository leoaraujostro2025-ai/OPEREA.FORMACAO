                <div key={item.pergunta} className="rounded-2xl border border-white/10 bg-white/5 p-5">
                  <div className="font-bold text-white">{item.pergunta}</div>
                  <p className="mt-2 text-sm leading-6 text-zinc-400">{item.resposta}</p>
                </div>
              ))}
            </div>
          </Card>

          <Card className="overflow-hidden border-amber-400/20 bg-gradient-to-b from-amber-500/12 via-white/5 to-white/5 p-6 md:p-8">
            <div className="text-sm font-semibold uppercase tracking-[0.22em] text-amber-400">CTA direto</div>
            <h2 className="mt-2 text-3xl font-black tracking-tight">Tirou a dúvida? Agora é agir.</h2>
            <p className="mt-4 leading-7 text-zinc-300">
              A página já conduziu o visitante por prova visual, proposta de valor, diferenciais, vídeo e perguntas principais. Agora o clique precisa estar fácil.
            </p>
            <div className="mt-6 flex flex-wrap gap-3">
              <ActionButton href={linkMatricula} primary icon={MessageCircle}>Quero me matricular</ActionButton>
              <ActionButton href={links.local} icon={MapPin}>Ver localização</ActionButton>
            </div>
          </Card>
        </section>

        <section id="contato" className="mt-8">
          <Card className="p-6 md:p-8">
            <div className="grid gap-6 lg:grid-cols-[1fr_auto] lg:items-center">
              <div>
                <div className="text-sm font-semibold uppercase tracking-[0.22em] text-amber-400">Contato</div>
                <h2 className="mt-2 text-3xl font-black tracking-tight md:text-4xl">Fale com a Opera e dê o próximo passo para sua formação.</h2>
                <p className="mt-4 max-w-2xl text-zinc-300 leading-7">
                  Chame no WhatsApp para tirar dúvidas, confirmar vaga e iniciar sua matrícula de forma rápida.
                </p>

                <div className="mt-6 flex flex-wrap gap-3">
                  <ActionButton href={linkMatricula} primary icon={Phone}>Fazer matrícula agora</ActionButton>
                  <ActionButton href={links.instagram} icon={Instagram}>Instagram</ActionButton>
                  <ActionButton href={links.facebook} icon={Facebook}>Facebook</ActionButton>
                  <ActionButton href={links.local} icon={MapPin}>Localização</ActionButton>
                </div>
              </div>

              <div className="rounded-[24px] border border-amber-400/20 bg-amber-500/10 px-6 py-5 text-sm text-amber-100">
                <div className="font-bold text-white">Observação</div>
                <p className="mt-2 leading-6 text-amber-100/90">
                  WhatsApp oficial da escola configurado para atendimento direto e matrícula rápida.
                </p>
              </div>
            </div>
          </Card>
        </section>

        <a
          href={linkMatricula}
          target="_blank"
          rel="noreferrer"
          className="fixed bottom-5 right-5 z-30 inline-flex items-center gap-2 rounded-full border border-amber-400/20 bg-amber-500 px-5 py-3 text-sm font-bold text-zinc-950 shadow-2xl shadow-black/30 transition hover:bg-amber-400"
        >
          <MessageCircle size={18} />
          Matrículas no WhatsApp
        </a>
      </div>
    </div>
  );
}
