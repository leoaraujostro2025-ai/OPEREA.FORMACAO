function gerarLinkWhatsapp(cidade) {
  const mensagem = cidade
    ? `Olá! Quero me inscrever no curso da Opera Formação para a cidade de ${cidade}.`
    : "Olá! Quero saber mais sobre os cursos da Opera Formação.";

  return `https://wa.me/5547992723707?text=${encodeURIComponent(mensagem)}`;
}

function ActionButton({ href, children, primary = false, icon: Icon }) {
  return (
    <a
      href={href}
      target="_blank"
      rel="noreferrer"
      className={`inline-flex items-center gap-2 rounded-2xl px-5 py-3 text-sm font-semibold transition-all duration-200 ${
        primary
          ? "bg-amber-500 text-zinc-950 hover:bg-amber-400"
          : "border border-white/15 bg-white/5 text-white hover:bg-white/10"
      }`}
    >
      {Icon ? <Icon size={18} /> : null}
      {children}
    </a>
  );
}

function Card({ children, className = "" }) {
  return (
    <div className={`rounded-[28px] border border-white/10 bg-white/5 shadow-2xl shadow-black/20 backdrop-blur ${className}`}>
      {children}
    </div>
  );
}

